FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "system";
    object      fvSchemes;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

ddtSchemes
{
    default         Euler implicit;
}

gradSchemes
{
        default         Gauss linear;
}

divSchemes
{
    default         none;
// alphaEqn
div(phiAlpha,alpha) Gauss limitedLinear01 1;
    div(phi,alpha)  Gauss upwind;//limitedLinear01 1;
    div(phir,alpha) Gauss upwind;//limitedLinear01 1;
    div(phiWRel,WRel) Gauss linear;
    div(phiRel,RelMixPar) Gauss upwind;
    div(phi,rho)  Gauss upwind;
    div(rhoPhi,U)  Gauss limitedLinearV 1;

// UEqn
    div(phi,U)    Gauss limitedLinearV 1;
// pEqn
    div(alpha,nu)   Gauss linear;
// alphaPlastic
    div(phi,alphaPlastic)  Gauss limitedLinear01 1;
// pa
    div(phi,pa_new_value)  Gauss limitedLinear 1;
    
//tau_Diffusion 
   div(tau_Diffusion)    Gauss  linear;
   div(tauTot)    Gauss  linear;
   div(tauTurb)    Gauss  linear;
}

laplacianSchemes
{
    default         none; 
// UEqn
    laplacian(nuEffa,U) Gauss linear corrected;
    laplacian(nuEffb,U) Gauss linear corrected;
    laplacian(nuFra,U)  Gauss linear corrected;
    laplacian(nuEffTotal,U) Gauss linear corrected;
    laplacian(nut,U) Gauss linear corrected;
    laplacian(muEff,U) Gauss linear corrected;
// pEqn
    laplacian((rho*(1|A(U))),p_rgh) Gauss linear corrected;
}

interpolationSchemes
{
    default  linear;
}

snGradSchemes
{
    default         corrected;
}

fluxRequired
{
    default         no;
    p_rgh               ;
}


